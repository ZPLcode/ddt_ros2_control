<mujoco model="ddt cargo out scene">
  <include file="robot_cargo_out.xml"/>

  <statistic center="0 0 0.1" extent="0.8"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="-130" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>
    <material name="rough" rgba="0.42 0.40 0.36 1"/>
    <hfield name="rugged" file="rugged.png" size="2.5 2 0.12 0.1"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane"/>

    <!-- symmetric up-and-over staircase: 8/10/12/14 cm rises, 0.40 m tread -->
    <geom pos="1.7 0 0.04" type="box" size="0.2 2 0.04"/>
    <geom pos="2.1 0 0.09" type="box" size="0.2 2 0.09"/>
    <geom pos="2.5 0 0.15" type="box" size="0.2 2 0.15"/>
    <geom pos="3.2 0 0.22" type="box" size="0.5 2 0.22"/>
    <geom pos="3.9 0 0.15" type="box" size="0.2 2 0.15"/>
    <geom pos="4.3 0 0.09" type="box" size="0.2 2 0.09"/>
    <geom pos="4.7 0 0.04" type="box" size="0.2 2 0.04"/>

    <!-- rugged height-field patch -->
    <geom type="hfield" hfield="rugged" pos="8.0 0 0" material="rough"/>
  </worldbody>
</mujoco>
